# Government APIs (free - sign up for keys)
BEA_API_KEY=
CENSUS_API_KEY=
BLS_API_KEY=
# Optional — live FBI crime API (static state estimates used when empty)
FBI_API_KEY=

# STR Data (Apify — https://console.apify.com/account/integrations)
# See PROTOTYPE-OPERATIONS.md for tuning guidance
APIFY_API_TOKEN=
APIFY_STR_MAX_LISTINGS=3
APIFY_RUN_TIMEOUT_SECS=300
APIFY_CLIENT_TIMEOUT_MS=330000
# Set to true to auto-fetch STR data when opening a market page (uses Apify on every new/incomplete market)
NEXT_PUBLIC_APIFY_STR_AUTO_FETCH=false

# Real Estate Data (Phase 2)
RENTCAST_API_KEY=
WALKSCORE_API_KEY=

# AI Agent (Market Brief + Compare & Rank + Discovery)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
AGENT_ENABLED=true

# Market Discovery Agent (§17)
DISCOVERY_ENABLED=true
DISCOVERY_STR_FETCH_MAX=5
DISCOVERY_STR_PREVIEW_POOL=15
DISCOVERY_SNAPSHOT_MAX_AGE_DAYS=30
DISCOVERY_HYDRATE_CONCURRENCY=4
DISCOVERY_MAX_HYDRATE=25

# Site gate (optional locally; set on Vercel for private production deploys)
SITE_PASSWORD=
# Optional — defaults to SITE_PASSWORD when empty; use a long random string in production
SITE_AUTH_SECRET=
